{
    "name": "vendor/laravel-whatsapp-cloud",
    "description": "A complete WhatsApp Cloud API Manager for Laravel with multi-account support, webhooks, queues, and admin panel",
    "keywords": [
        "laravel",
        "laravel-package",
        "whatsapp",
        "whatsapp-cloud-api",
        "meta",
        "messaging",
        "notifications",
        "webhook"
    ],
    "homepage": "https://github.com/ashararsi/ashararsi-laravel-whatsapp-cloud",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Vendor",
            "email": "hello@example.com",
            "homepage": "https://github.com/vendor",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/ashararsi/ashararsi-laravel-whatsapp-cloud/issues",
        "source": "https://github.com/ashararsi/ashararsi-laravel-whatsapp-cloud",
        "docs": "https://github.com/ashararsi/ashararsi-laravel-whatsapp-cloud#readme"
    },
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/notifications": "^13.0",
        "illuminate/routing": "^13.0",
        "illuminate/support": "^13.0",
        "illuminate/queue": "^13.0",
        "illuminate/console": "^13.0",
        "illuminate/view": "^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "phpunit/phpunit": "^11.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Vendor\\LaravelWhatsAppCloud\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vendor\\LaravelWhatsAppCloud\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vendor\\LaravelWhatsAppCloud\\WhatsAppServiceProvider"
            ],
            "aliases": {
                "WhatsApp": "Vendor\\LaravelWhatsAppCloud\\Facades\\WhatsApp"
            }
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-text"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
