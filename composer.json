{
    "name": "ashararsi/laravel-whatsapp-cloud",
    "description": "Production-ready WhatsApp messaging for Laravel 13 with Meta Cloud API and Twilio providers, multi-account support, webhooks, queues, conversation tracking, notifications, and admin panel",
    "keywords": [
        "laravel",
        "laravel-package",
        "laravel-13",
        "whatsapp",
        "whatsapp-cloud-api",
        "whatsapp-business",
        "meta",
        "twilio",
        "messaging",
        "notifications",
        "webhook",
        "conversations",
        "multi-account",
        "admin-panel"
    ],
    "homepage": "https://github.com/ashararsi/ashararsi-laravel-whatsapp-cloud",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Ashar",
            "email": "57168419+ashararsi@users.noreply.github.com",
            "homepage": "https://github.com/ashararsi",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/ashararsi/ashararsi-laravel-whatsapp-cloud/issues",
        "source": "https://github.com/ashararsi/ashararsi-laravel-whatsapp-cloud"
    },
    "require": {
        "php": "^8.3",
        "illuminate/console": "^13.0",
        "illuminate/contracts": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/notifications": "^13.0",
        "illuminate/queue": "^13.0",
        "illuminate/routing": "^13.0",
        "illuminate/support": "^13.0",
        "illuminate/view": "^13.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^11.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Vendor\\LaravelWhatsAppCloud\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vendor\\LaravelWhatsAppCloud\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vendor\\LaravelWhatsAppCloud\\WhatsAppServiceProvider"
            ],
            "aliases": {
                "WhatsApp": "Vendor\\LaravelWhatsAppCloud\\Facades\\WhatsApp"
            }
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-text"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
